<windowing:AppWindow xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:ClipboardManager.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="using:FluentAvalonia.UI.Controls"
    xmlns:windowing="clr-namespace:FluentAvalonia.UI.Windowing;assembly=FluentAvalonia"
    mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
    x:Class="ClipboardManager.Views.MainWindow"
    x:DataType="vm:MainWindowViewModel"
    Icon="/Assets/clipboardIcon.png"
    Title="ClipboardManager">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <ui:NavigationView x:Name="nav"
        HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch"
        PaneDisplayMode="Auto"
        IsSettingsVisible="True"
        SelectionChanged="NavView_SelectionChanged"
        >

        <ui:NavigationView.Content>
            <ContentControl x:Name="PageContent" />
        </ui:NavigationView.Content>
        

    </ui:NavigationView>

</windowing:AppWindow>