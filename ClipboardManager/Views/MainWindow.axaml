<windowing:AppWindow xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:ClipboardManager.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="using:FluentAvalonia.UI.Controls"
    xmlns:windowing="clr-namespace:FluentAvalonia.UI.Windowing;assembly=FluentAvalonia"
    mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
    x:Class="ClipboardManager.Views.MainWindow"
    x:DataType="vm:MainWindowViewModel"
    Icon="/Assets/clipboardIcon.png"
    Title="ClipboardManager">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <ui:NavigationView x:Name="nvSample2"
        HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch"
        PaneDisplayMode="Auto">

        <!-- <ui:NavigationView.MenuItems> -->
        <!--     <ui:NavigationViewItem Content="Menu Item1" Tag="SamplePage1" IconSource="Play"/> -->
        <!--     <ui:NavigationViewItem Content="Menu Item2" Tag="SamplePage2" IconSource="Save"/> -->
        <!--     <ui:NavigationViewItem Content="Menu Item3" Tag="SamplePage3" IconSource="Refresh"/> -->
        <!--     <ui:NavigationViewItem Content="Menu Item4" Tag="SamplePage4" IconSource="Download"/> -->
        <!-- </ui:NavigationView.MenuItems> -->

        <!-- Clipboard history displayed in the NavigationView content area -->
        <ListBox ItemsSource="{Binding ClipboardHistory}"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch">
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="x:String">
                    <Border Margin="0,10,0,0"
                        CornerRadius="5"
                        Height="150"
                        BorderBrush="Gray" BorderThickness="1"
                        Padding="5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- Clipboard text -->
                            <TextBlock Grid.Column="0"
                                Text="{Binding}"
                                TextWrapping="Wrap"
                                VerticalAlignment="Top"
                                Margin="4,4,8,4" />

                            <!-- Action buttons pinned to top-right -->
                            <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Top"
                                Spacing="4">
                                <Button Content="Copy"
                                    Command="{Binding $parent[ListBox].((vm:MainWindowViewModel)DataContext).CopyEntryCommand}"
                                    CommandParameter="{Binding}" />
                                <Button Content="Delete"
                                    Command="{Binding $parent[ListBox].((vm:MainWindowViewModel)DataContext).DeleteEntryCommand}"
                                    CommandParameter="{Binding}" />
                            </StackPanel>

                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

    </ui:NavigationView>

</windowing:AppWindow>