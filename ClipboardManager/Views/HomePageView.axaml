<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:ClipboardManager.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:DataType="vm:HomePageViewModel"
             x:Class="ClipboardManager.Views.HomePageView">
    
    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
             to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:HomePageViewModel/>
    </Design.DataContext>
    
    <StackPanel Margin="20">
        <TextBlock Margin="0 5" FontSize="24" FontFamily="Montserrat">Clipboard:</TextBlock>
        <ListBox ItemsSource="{Binding ClipboardHistory}"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch">
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="x:String">
                    <Border Margin="0,10,0,0"
                        CornerRadius="5"
                        Height="150"
                        BorderBrush="Gray" BorderThickness="1"
                        Padding="5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- Clipboard text -->
                            <TextBlock Grid.Column="0"
                                Text="{Binding}"
                                TextWrapping="Wrap"
                                VerticalAlignment="Top"
                                Margin="4,4,8,4" />

                            <!-- Action buttons pinned to top-right -->
                            <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Top"
                                Spacing="4">
                                <Button Content="Copy"
                                        Command="{Binding $parent[ListBox].((vm:HomePageViewModel)DataContext).CopyEntryCommand}"
                                        CommandParameter="{Binding}" />
                                <Button Content="Delete"
                                        Command="{Binding $parent[ListBox].((vm:HomePageViewModel)DataContext).DeleteEntryCommand}"
                                        CommandParameter="{Binding}" />
                            </StackPanel>

                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </StackPanel>
</UserControl>
